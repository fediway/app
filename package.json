{
  "name": "monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@10.8.0",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:mock": "VITE_API_MODE=mock turbo run dev",
    "dev:web": "turbo run dev --filter=@repo/web",
    "dev:web:mock": "VITE_API_MODE=mock turbo run dev --filter=@repo/web",
    "dev:web:live": "VITE_API_MODE=live turbo run dev --filter=@repo/web",
    "dev:mobile": "turbo run dev --filter=@repo/mobile",
    "dev:mobile:mock": "VITE_API_MODE=mock turbo run dev --filter=@repo/mobile",
    "dev:storybook": "turbo run dev --filter=@repo/storybook",
    "build:storybook": "turbo run build --filter=@repo/storybook",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "lint:fix": "eslint --fix .",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:api": "turbo run test --filter=@repo/api",
    "test:ui": "turbo run test --filter=@repo/ui",
    "test:mobile": "turbo run test --filter=@repo/mobile",
    "check-size": "node scripts/check-bundle-size.mjs"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.4.3",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.39.2",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^15.7.4",
    "lint-staged": "^16.2.7",
    "shadcn-vue": "^2.4.3",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.3.0",
    "vitest": "^2.1.8"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,mjs,mts,vue,json,md}": "eslint --fix"
  }
}
