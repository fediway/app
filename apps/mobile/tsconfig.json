{
  "extends": "@repo/config/typescript",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["vite/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "*.config.ts"],
  "exclude": ["node_modules", "dist", "ios", "android"]
}
