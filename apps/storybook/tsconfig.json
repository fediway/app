{
  "extends": "@repo/config/typescript",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "baseUrl": ".",
    "paths": {
      "@/*": ["../../packages/ui/src/*"]
    }
  },
  "include": [
    ".storybook/**/*.ts",
    "stories/**/*.ts",
    "../../packages/ui/src/**/*.ts",
    "../../packages/ui/src/**/*.vue"
  ],
  "exclude": ["node_modules", "storybook-static"]
}
