{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".nuxt/**", ".output/**", "dist/**", "storybook-static/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["VITE_API_MODE", "FEEDBACK_KANEO_BASE_URL", "FEEDBACK_KANEO_API_KEY", "FEEDBACK_KANEO_PROJECT_ID"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "test/**", "vitest.config.*"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    }
  }
}
